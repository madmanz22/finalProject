local players = game:GetService("Players")
local PathfindingService = game:GetService("PathfindingService")
local RunService = game:GetService("RunService")

local npc = script.Parent
local humanoid = npc:WaitForChild("Humanoid")
local rootPart = npc:WaitForChild("HumanoidRootPart")

humanoid walkSpeed = 16

local function findPlayer()
	local nearplayer = nil
	local shortDis = math.huge
	for i, player in pairs(Players:GetPlayers()) do
		if player.Character then
			local dis = (player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
			if dis < shortDis and dis < 60 then
				shortDis = dis
				nearplayer = player.Character
			end
		end
	end
	return nearplayer
end

local function moveTo(tarPos)
	local path = PathfindingService:CreatePath()
	Path:ComputeAsync(rootPart.Position, tarPos.Position)
	
	if Path.Status == Enum.PathStatus.Success then
		for i, waypoint in pairs(Path:GetWaypoints()) do
			humanoid:MoveTo(waypoint.Position)
			humanoid.MoveToFinished:Wait()
		end
	end
end
RunService.Heartbeat:Connect(function())
	if humanoid.Health <=0 then return end
	
	local nearplayer = findPlayer()
	if nearplayer == nil then return end
		
	local TargetRootPart = nearplayer:WaitForChild("HumanoidRootPart")
	local TargetHumanoid = nearplayer:WaitForChild("Humanoid")
	if TargetHumanoid == nil then return end
	local distance = (TargetRootPart.Position - rootPart.Position).Magnitude
	moveTo(TargetRootPart.Position)
end)
