local PathfindingService = game:GetService("PathfindingService")
local Players = game:GetService("Players")

local npc = script.Parent
local humanoid = npc:WaitForChild("Humanoid")
local root = npc:WaitForChild("HumanoidRootPart")




local DETECTION_RANGE = 100
local ATTACK_RANGE = 7
local MEMORY_TIME = 5
humanoid.WalkSpeed = 30


local waypointsFolder = workspace:FindFirstChild("Waypoints")
local patrolPoints = waypointsFolder and waypointsFolder:GetChildren() or {}
local lastSeenTime = 0
local currentTarget = nil

local animation = script:WaitForChild('Animation')
local humanoid = script.Parent:WaitForChild('Humanoid')
local dance = humanoid:LoadAnimation(animation)


local function canSeePlayer(player)
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
		return false
	end

	local targetRoot = player.Character.HumanoidRootPart
	local direction = (targetRoot.Position - root.Position)

	if direction.Magnitude > DETECTION_RANGE then
		return false
	end

	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {npc}
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	local ray = workspace:Raycast(root.Position, direction, rayParams)

	if ray and ray.Instance then
		return ray.Instance:IsDescendantOf(player.Character)
	end

	return false
end

local function getTarget()
	for _, player in pairs(Players:GetPlayers()) do
		if canSeePlayer(player) then
			return player
		end
	end
	return nil
end

local function moveTo(position)
	local path = PathfindingService:CreatePath()
	path:ComputeAsync(root.Position, position)

	if path.Status == Enum.PathStatus.Success then
		dance:Play()
		for _, waypoint in ipairs(path:GetWaypoints()) do
			humanoid:MoveTo(waypoint.Position)
			

			if waypoint.Action == Enum.PathWaypointAction.Jump then
				humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			end

			humanoid.MoveToFinished:Wait()
		end
	else
		humanoid:MoveTo(position)
	end
end

local function patrol()
	if #patrolPoints == 0 then return end

	local point = patrolPoints[math.random(1, #patrolPoints)]
	moveTo(point.Position)
end

root.Touched:Connect(function(hit)
	local character = hit.Parent
	local hum = character and character:FindFirstChild("Humanoid")

	if hum and Players:GetPlayerFromCharacter(character) then
		hum.Health = 0 -- instant kill
		game.Players:FindFirstChild(hit.Parent.Name).PlayerGui.JumpScareGui.Enabled = true
		script.Parent.Sound:play()
		wait(2)
		game.Players:FindFirstChild(hit.Parent.Name).PlayerGui.JumpScareGui.Enabled = false
		
	end
end)

while true do
	local seenPlayer = getTarget()

	if seenPlayer then
		currentTarget = seenPlayer
		lastSeenTime = tick()
	end

	if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild("HumanoidRootPart") then
		local targetPos = currentTarget.Character.HumanoidRootPart.Position

		if tick() - lastSeenTime <= MEMORY_TIME then
			moveTo(targetPos)
		else
			currentTarget = nil
		end
	else
		patrol()
	end

	wait(0.3)
end